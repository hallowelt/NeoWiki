{
	"$schema": "https://json-schema.org/draft/2020-12/schema#",
	"type": "object",
	"properties": {
		"description": {
			"type": "string"
		},
		"propertyDefinitions": {
			"type": "object",
			"patternProperties": {
				"^.*$": {
					"type": "object",
					"additionalProperties": true,
					"required": [
						"type"
					],
					"properties": {
						"description": {
							"type": "string"
						},
						"type": {
							"type": "string",
							"minLength": 1
						},
						"required": {
							"type": "boolean"
						},
						"multiple": {
							"type": "boolean"
						},
						"uniqueItems": {
							"type": "boolean"
						}
					}
				}
			}
		}
	},
	"required": [
		"propertyDefinitions"
	],
	"additionalProperties": true
}
