{
	"name": "NeoWiki",

	"version": "0.0.0-alpha",

	"author": [
		"[https://Professional.Wiki/ Professional Wiki]",
		"[https://www.EntropyWins.wtf/mediawiki Jeroen De Dauw]"
	],

	"url": "https://github.com/ProfessionalWiki/NeoWiki",

	"license-name": "GPL-2.0-or-later",

	"descriptionmsg": "neowiki-description",

	"requires": {
		"MediaWiki": ">= 1.43.0"
	},

	"MessagesDirs": {
		"NeoWiki": [
			"i18n"
		]
	},

	"AutoloadNamespaces": {
		"ProfessionalWiki\\NeoWiki\\": "src/"
	},

	"TestAutoloadNamespaces": {
		"ProfessionalWiki\\NeoWiki\\Tests\\": "tests/phpunit",
		"ProfessionalWiki\\RedHerb\\": "tests/RedHerb/src"
	},

	"Hooks": {
		"MediaWikiServices": "ProfessionalWiki\\NeoWiki\\EntryPoints\\NeoWikiHooks::onMediaWikiServices",

		"ParserFirstCallInit": "ProfessionalWiki\\NeoWiki\\EntryPoints\\NeoWikiHooks::onParserFirstCallInit",

		"RevisionFromEditComplete": "ProfessionalWiki\\NeoWiki\\EntryPoints\\NeoWikiHooks::onRevisionFromEditComplete",
		"PageDeleteComplete": "ProfessionalWiki\\NeoWiki\\EntryPoints\\NeoWikiHooks::onPageDeleteComplete",
		"RevisionUndeleted": "ProfessionalWiki\\NeoWiki\\EntryPoints\\NeoWikiHooks::onRevisionUndeleted",
		"PageMoveComplete": "ProfessionalWiki\\NeoWiki\\EntryPoints\\NeoWikiHooks::onPageMoveComplete",

		"CodeEditorGetPageLanguage": "ProfessionalWiki\\NeoWiki\\EntryPoints\\NeoWikiHooks::onCodeEditorGetPageLanguage",

		"BeforePageDisplay": "ProfessionalWiki\\NeoWiki\\EntryPoints\\NeoWikiHooks::onBeforePageDisplay",

		"EditFilter": "ProfessionalWiki\\NeoWiki\\EntryPoints\\NeoWikiHooks::onEditFilter",

		"SpecialPage_initList": "ProfessionalWiki\\NeoWiki\\EntryPoints\\NeoWikiHooks::onSpecialPageInitList",

		"ContentModelCanBeUsedOn": "ProfessionalWiki\\NeoWiki\\EntryPoints\\NeoWikiHooks::onContentModelCanBeUsedOn",

		"SidebarBeforeOutput": "ProfessionalWiki\\NeoWiki\\EntryPoints\\NeoWikiHooks::onSidebarBeforeOutput",
		"ScribuntoExternalLibraries": "ProfessionalWiki\\NeoWiki\\EntryPoints\\NeoWikiHooks::onScribuntoExternalLibraries"
	},

	"ContentHandlers": {
		"NeoWikiSubject": "ProfessionalWiki\\NeoWiki\\EntryPoints\\Content\\SubjectContentHandler",
		"NeoWikiSchema": "ProfessionalWiki\\NeoWiki\\EntryPoints\\Content\\SchemaContentHandler",
		"NeoWikiLayout": "ProfessionalWiki\\NeoWiki\\EntryPoints\\Content\\LayoutContentHandler"
	},

	"namespaces": [
		{
			"id": 7474,
			"constant": "NS_NEOWIKI_SCHEMA",
			"name": "Schema",
			"defaultcontentmodel": "NeoWikiSchema",
			"subpages": false,
			"content": false,
			"movable": false,
			"protection": "neowiki-schema-edit"
		},
		{
			"id": 7475,
			"constant": "NS_NEOWIKI_SCHEMA_TALK",
			"name": "Schema_talk"
		},
		{
			"id": 7476,
			"constant": "NS_NEOWIKI_LAYOUT",
			"name": "Layout",
			"defaultcontentmodel": "NeoWikiLayout",
			"subpages": false,
			"content": false,
			"movable": false,
			"protection": "neowiki-layout-edit"
		},
		{
			"id": 7477,
			"constant": "NS_NEOWIKI_LAYOUT_TALK",
			"name": "Layout_talk"
		}
	],

	"AvailableRights": [
		"neowiki-schema-edit",
		"neowiki-layout-edit"
	],

	"GroupPermissions": {
		"sysop": {
			"neowiki-schema-edit": true,
			"neowiki-layout-edit": true
		},
		"interface-admin": {
			"neowiki-schema-edit": true,
			"neowiki-layout-edit": true
		}
	},

	"SpecialPages": {
		"NeoJson": "ProfessionalWiki\\NeoWiki\\EntryPoints\\SpecialPages\\SpecialNeoJson",
		"Schemas": "ProfessionalWiki\\NeoWiki\\EntryPoints\\SpecialPages\\SpecialSchemas",
		"Layouts": "ProfessionalWiki\\NeoWiki\\EntryPoints\\SpecialPages\\SpecialLayouts"
	},

	"config": {
		"NeoWikiEnableDevelopmentUI": {
			"description": "Whether development UIs should be enabled",
			"value": false
		}
	},

	"ExtensionMessagesFiles": {
		"NeoWikiAliases": "i18n/_Aliases.php",
		"NeoWikiNamespaces": "i18n/_Namespaces.php",
		"NeoWikiMagic": "i18n/_Magic.php"
	},

	"RestRoutes": [
		{
			"path": "/neowiki/v0/page/{pageId}/mainSubject",
			"method": [ "POST" ],
			"factory": "ProfessionalWiki\\NeoWiki\\NeoWikiExtension::newCreateMainSubjectApi"
		},
		{
			"path": "/neowiki/v0/page/{pageId}/childSubjects",
			"method": [ "POST" ],
			"factory": "ProfessionalWiki\\NeoWiki\\NeoWikiExtension::newCreateChildSubjectApi"
		},
		{
			"path": "/neowiki/v0/subject/{subjectId}",
			"method": [ "GET" ],
			"factory": "ProfessionalWiki\\NeoWiki\\NeoWikiExtension::newGetSubjectApi"
		},
		{
			"path": "/neowiki/v0/subject/{subjectId}",
			"method": [ "PATCH" ],
			"factory": "ProfessionalWiki\\NeoWiki\\NeoWikiExtension::newPatchSubjectApi"
		},
		{
			"path": "/neowiki/v0/subject/{subjectId}",
			"method": [ "DELETE" ],
			"factory": "ProfessionalWiki\\NeoWiki\\NeoWikiExtension::newDeleteSubjectApi"
		},
		{
			"path": "/neowiki/v0/schema/{schemaName}",
			"method": [ "GET" ],
			"factory": "ProfessionalWiki\\NeoWiki\\NeoWikiExtension::newGetSchemaApi"
		},
		{
			"path": "/neowiki/v0/layout/{layoutName}",
			"method": [ "GET" ],
			"factory": "ProfessionalWiki\\NeoWiki\\NeoWikiExtension::newGetLayoutApi"
		},
		{
			"path": "/neowiki/v0/layouts",
			"method": [ "GET" ],
			"factory": "ProfessionalWiki\\NeoWiki\\NeoWikiExtension::newGetLayoutSummariesApi"
		},
		{
			"path": "/neowiki/v0/schema-names/{search}",
			"method": [ "GET" ],
			"factory": "ProfessionalWiki\\NeoWiki\\NeoWikiExtension::newGetSchemaNamesApi"
		},
		{
			"path": "/neowiki/v0/subject-labels",
			"method": [ "GET" ],
			"factory": "ProfessionalWiki\\NeoWiki\\NeoWikiExtension::newGetSubjectLabelsApi"
		},
		{
			"path": "/neowiki/v0/schemas",
			"method": [ "GET" ],
			"factory": "ProfessionalWiki\\NeoWiki\\NeoWikiExtension::newGetSchemaSummariesApi"
		}
	],

	"ResourceFileModulePaths": {
		"localBasePath": "",
		"remoteExtPath": "NeoWiki"
	},

